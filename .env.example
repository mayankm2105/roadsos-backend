# ─── Core ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development         # "development" | "production"
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# ─── Database ──────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./data/roadsos_cache.db

# ─── Google APIs (same key works for both Places + Geocoding) ──────────────
GOOGLE_PLACES_API_KEY=          # Required for /services/* endpoints
GOOGLE_GEOCODING_API_KEY=       # Optional — falls back to GOOGLE_PLACES_API_KEY

# ─── AI ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=                 # Required for /chat/* and /triage/* endpoints
GEMINI_MODEL=gemini-1.5-flash   # Do not change unless upgrading model

# ─── Speech-to-Text (local Whisper — no key needed) ──────────────────────
WHISPER_MODEL=base              # tiny | base | small (base recommended)

# ─── SOS Links ─────────────────────────────────────────────────────────────
SOS_BASE_URL=http://localhost:5173/sos/   # Change to Vercel URL in production
SOS_LINK_TTL_HOURS=24

# ─── Admin ─────────────────────────────────────────────────────────────────
ADMIN_KEY=change-me-before-deploy   # Used for POST /offline/cache/sync

# ─── CORS (comma-separated origins) ───────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# In production add: https://your-app.vercel.app
